{
  "schemaVersion": 2,
  "id": "system-hermes-agent",
  "name": "Hermes Agent",
  "packageType": "user",
  "defaultEnabled": true,
  "description": "Connect to a running Hermes Agent instance and use Neon Pilot as its session interface.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "readConfig",
        "handler": "readConfig",
        "title": "Read Hermes connection",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "updateConfig",
        "handler": "updateConfig",
        "title": "Update Hermes connection",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "deleteDeployment",
        "handler": "deleteDeployment",
        "title": "Delete Hermes deployment",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "health",
        "handler": "health",
        "title": "Check Hermes health",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "capabilities",
        "handler": "capabilities",
        "title": "Read Hermes capabilities",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "listSessions",
        "handler": "listSessions",
        "title": "List Hermes sessions",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "createSession",
        "handler": "createSession",
        "title": "Create Hermes session",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "getMessages",
        "handler": "getMessages",
        "title": "Read Hermes session messages",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "sendMessage",
        "handler": "sendMessage",
        "title": "Send Hermes session message",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "startSessionRun",
        "handler": "startSessionRun",
        "title": "Start Hermes session run",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "getRun",
        "handler": "getRun",
        "title": "Read Hermes run status",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "renameSession",
        "handler": "renameSession",
        "title": "Rename Hermes session",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "forkSession",
        "handler": "forkSession",
        "title": "Fork Hermes session",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "deleteSession",
        "handler": "deleteSession",
        "title": "Delete Hermes session",
        "worker": {
          "enabled": true
        }
      }
    ]
  },
  "contributes": {
    "nav": [
      {
        "id": "hermes-nav",
        "label": "Hermes",
        "route": "/ext/hermes",
        "icon": "sparkle",
        "section": "primary",
        "sidebarView": "sessions-sidebar"
      }
    ],
    "views": [
      {
        "id": "page",
        "title": "Hermes Agent",
        "location": "main",
        "route": "/ext/hermes",
        "component": "HermesAgentPage",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      },
      {
        "id": "sessions-sidebar",
        "title": "Hermes Sessions",
        "location": "sidebar",
        "component": "HermesSessionsSidebar"
      }
    ],
    "settingsComponent": {
      "id": "hermes-settings",
      "component": "HermesSettingsPanel",
      "sectionId": "settings-hermes",
      "label": "Hermes Agent",
      "description": "Configure the Hermes Agent API connection.",
      "order": 40
    }
  },
  "permissions": [
    "storage:readwrite",
    "ui:notify"
  ],
  "compatibility": {
    "neonPilot": ">=0.10.0 <0.12.0",
    "extensionApi": "^2"
  }
}
