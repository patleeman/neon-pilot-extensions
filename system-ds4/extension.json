{
  "schemaVersion": 2,
  "id": "system-ds4",
  "name": "DS4",
  "packageType": "system",
  "defaultEnabled": false,
  "description": "DeepSeek V4 Flash local model profile and ds4-agent-shaped tools for antirez/ds4.",
  "version": "0.1.3",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "src/backend.ts",
    "agentExtension": "createDs4AgentExtension",
    "onEnableAction": "ds4InstallProvider",
    "onDisableAction": "ds4Disable",
    "services": [
      {
        "id": "ds4-runtime",
        "handler": "runtimeService",
        "stopHandler": "stopServer",
        "healthCheck": "runtimeServiceHealth",
        "title": "DS4 runtime cleanup",
        "description": "Stops the managed ds4-server process when Neon Pilot shuts down, reloads, or disables DS4.",
        "restart": "never",
        "worker": {
          "enabled": true
        }
      }
    ],
    "protocolEntrypoints": [
      {
        "id": "ds4-tools",
        "handler": "ds4ToolsCli",
        "title": "DS4 tool CLI",
        "description": "Compact CLI gateway for extension tools intentionally withheld from the DS4 model schema."
      }
    ],
    "actions": [
      {
        "id": "ds4InstallProvider",
        "handler": "installProvider",
        "title": "Install DS4 model provider",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4Disable",
        "handler": "disable",
        "title": "Disable DS4 model provider",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4Status",
        "handler": "status",
        "title": "DS4 server status",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4Discover",
        "handler": "discover",
        "title": "Discover DS4 model",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4BootstrapRuntime",
        "handler": "bootstrapRuntime",
        "title": "Download and build DS4 runtime",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4StartServer",
        "handler": "startServer",
        "title": "Start managed DS4 server",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4StopServer",
        "handler": "stopServer",
        "title": "Stop managed DS4 server",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4RevealRuntimeFolder",
        "handler": "revealRuntimeFolder",
        "title": "Reveal DS4 runtime folder",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4RevealModelFile",
        "handler": "revealModelFile",
        "title": "Reveal DS4 model file",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4ClearKvCache",
        "handler": "clearKvCache",
        "title": "Clear DS4 KV cache",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4InstallRtk",
        "handler": "installRtk",
        "title": "Install RTK shell output compression",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4GetSettings",
        "handler": "getSettings",
        "title": "Get DS4 settings",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4SaveSettings",
        "handler": "saveSettings",
        "title": "Save DS4 settings",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "ds4OptimizePromptAssembly",
        "handler": "optimizePromptAssembly",
        "title": "Optimize DS4 prompt assembly",
        "worker": {
          "enabled": true
        }
      }
    ]
  },
  "contributes": {
    "settingsComponent": {
      "id": "ds4-runtime",
      "component": "Ds4RuntimeSettings",
      "sectionId": "settings-ds4",
      "label": "DS4",
      "description": "Install and manage the local ds4.c runtime.",
      "order": 40
    },
    "modelDiscovery": {
      "action": "ds4Discover"
    },
    "modelProfiles": [
      {
        "id": "ds4-compatible",
        "title": "DS4 Compatible",
        "description": "DeepSeek V4 Flash served by local ds4-server.",
        "match": [
          "ds4/*"
        ],
        "priority": 100,
        "startupAction": "ds4StartServer",
        "activeTools": [
          "bash",
          "read",
          "edit"
        ]
      }
    ],
    "skills": [
      {
        "id": "ds4-local-agent",
        "title": "DS4 Local Agent",
        "description": "Use when the selected model is local DeepSeek V4 Flash served by ds4-server.",
        "path": "skills/ds4-local-agent/SKILL.md"
      }
    ],
    "promptAssemblyHooks": [
      {
        "id": "ds4-progressive-disclosure",
        "handler": "ds4OptimizePromptAssembly",
        "title": "DS4 progressive disclosure",
        "phase": "before-injection",
        "priority": 100
      }
    ]
  },
  "permissions": [
    "network:read",
    "network:write",
    "shell:exec",
    "shell:execute",
    "conversations:readwrite"
  ],
  "compatibility": {
    "neonPilot": ">=0.10.0 <0.11.0",
    "extensionApi": "^2"
  }
}
