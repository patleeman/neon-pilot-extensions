{
  "schemaVersion": 2,
  "id": "system-duckduckgo-search",
  "name": "DuckDuckGo Search",
  "packageType": "user",
  "description": "Agent web search tool backed by DuckDuckGo HTML results.",
  "version": "0.1.0",
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "duckDuckGoSearch",
        "handler": "duckDuckGoSearch",
        "title": "Search with DuckDuckGo",
        "worker": {
          "enabled": true
        }
      }
    ]
  },
  "contributes": {
    "tools": [
      {
        "id": "duckduckgo-search",
        "name": "web_search",
        "title": "Search web",
        "description": "Agent web search tool that fetches DuckDuckGo's HTML page and returns titles, URLs, and snippets.",
        "action": "duckDuckGoSearch",
        "priority": 10,
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query"
            },
            "count": {
              "type": "number",
              "description": "Number of results to return (default: 5, max: 20)"
            },
            "page": {
              "type": "number",
              "description": "Page number for pagination (default: 1)"
            }
          },
          "required": [
            "query"
          ],
          "additionalProperties": false
        }
      }
    ]
  },
  "permissions": [
    "network:read"
  ],
  "compatibility": {
    "neonPilot": ">=0.10.0 <0.12.0",
    "extensionApi": "^2"
  }
}
