{
  "schemaVersion": 2,
  "id": "system-alleycat",
  "name": "Kitty Litter Mobile Pairing (Alleycat)",
  "packageType": "user",
  "defaultEnabled": false,
  "description": "Pair the Kitty Litter iOS app directly with Neon Pilot using a PA-owned Alleycat-compatible host and Codex-shaped conversation APIs.",
  "version": "0.1.1",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "dist/backend.mjs",
    "services": [
      {
        "id": "host",
        "handler": "startService",
        "title": "Kitty Litter companion host",
        "description": "Runs the PA-owned Alleycat-compatible host while the extension is enabled.",
        "healthCheck": "status",
        "stopHandler": "stop",
        "restart": "on-failure",
        "worker": {
          "enabled": true
        }
      }
    ],
    "actions": [
      {
        "id": "alleycatStart",
        "handler": "start",
        "title": "Start Alleycat host",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "alleycatStop",
        "handler": "stop",
        "title": "Stop Alleycat host",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "alleycatStatus",
        "handler": "status",
        "title": "Alleycat host status",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "rotateToken",
        "handler": "rotateToken",
        "title": "Rotate Alleycat pairing token",
        "worker": {
          "enabled": true
        }
      }
    ]
  },
  "contributes": {
    "settingsComponent": {
      "id": "alleycat",
      "component": "AlleycatSettingsPanel",
      "sectionId": "settings-alleycat",
      "label": "Kitty Litter Mobile Pairing",
      "description": "Scan a PA-owned pairing QR from the Kitty Litter iOS app. Do not run npx kittylitter.",
      "order": 21
    }
  },
  "permissions": [
    "conversations:read",
    "conversations:write",
    "conversations:readwrite",
    "network:listen",
    "storage:readwrite"
  ],
  "compatibility": {
    "neonPilot": ">=0.10.0",
    "extensionApi": "^2"
  }
}
