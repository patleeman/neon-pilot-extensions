{
  "schemaVersion": 2,
  "id": "system-knowledge",
  "name": "Knowledge",
  "packageType": "user",
  "defaultEnabled": false,
  "description": "Browse and edit knowledge base files beside the active conversation.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": ["src/components/knowledge.css"]
  },
  "backend": {
    "entry": "src/backend.ts",
    "actions": [
      {
        "id": "readState",
        "handler": "readState",
        "title": "Read knowledge state",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "updateState",
        "handler": "updateState",
        "title": "Update knowledge state",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "sync",
        "handler": "sync",
        "title": "Sync knowledge base",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "provideKnowledgeInstructions",
        "handler": "provideKnowledgeInstructions",
        "title": "Provide knowledge path instructions",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeListFiles",
        "handler": "knowledgeListFiles",
        "title": "List knowledge files",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeTree",
        "handler": "knowledgeTree",
        "title": "Read knowledge tree",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeReadFile",
        "handler": "knowledgeReadFile",
        "title": "Read knowledge file",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeWriteFile",
        "handler": "knowledgeWriteFile",
        "title": "Write knowledge file",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeCreateFolder",
        "handler": "knowledgeCreateFolder",
        "title": "Create knowledge folder",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeDeleteFile",
        "handler": "knowledgeDeleteFile",
        "title": "Delete knowledge entry",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeRename",
        "handler": "knowledgeRename",
        "title": "Rename knowledge entry",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeMove",
        "handler": "knowledgeMove",
        "title": "Move knowledge entry",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeBacklinks",
        "handler": "knowledgeBacklinks",
        "title": "Read knowledge backlinks",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeSearch",
        "handler": "knowledgeSearch",
        "title": "Search knowledge",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeUploadImage",
        "handler": "knowledgeUploadImage",
        "title": "Upload knowledge image",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeImportUrl",
        "handler": "knowledgeImportUrl",
        "title": "Import URL into knowledge",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "knowledgeImportSharedItem",
        "handler": "knowledgeImportSharedItem",
        "title": "Import shared item into knowledge",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "readMemory",
        "handler": "readMemory",
        "title": "Read memory",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "resolvePromptReferences",
        "handler": "resolvePromptReferences",
        "title": "Resolve knowledge prompt references",
        "worker": {
          "enabled": true
        }
      }
    ],
    "routes": [
      {
        "method": "GET",
        "path": "/asset",
        "handler": "asset",
        "title": "Read knowledge asset",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "GET",
        "path": "/knowledge/tree",
        "handler": "knowledgeTreeRoute",
        "title": "Read knowledge tree route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "GET",
        "path": "/knowledge/file",
        "handler": "knowledgeReadFileRoute",
        "title": "Read knowledge file route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "PUT",
        "path": "/knowledge/file",
        "handler": "knowledgeWriteFileRoute",
        "title": "Write knowledge file route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "DELETE",
        "path": "/knowledge/file",
        "handler": "knowledgeDeleteFileRoute",
        "title": "Delete knowledge file route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "POST",
        "path": "/knowledge/folder",
        "handler": "knowledgeCreateFolderRoute",
        "title": "Create knowledge folder route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "POST",
        "path": "/knowledge/rename",
        "handler": "knowledgeRenameRoute",
        "title": "Rename knowledge entry route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "POST",
        "path": "/knowledge/move",
        "handler": "knowledgeMoveRoute",
        "title": "Move knowledge entry route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "GET",
        "path": "/knowledge/backlinks",
        "handler": "knowledgeBacklinksRoute",
        "title": "Read knowledge backlinks route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "GET",
        "path": "/knowledge/search",
        "handler": "knowledgeSearchRoute",
        "title": "Search knowledge route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "GET",
        "path": "/knowledge/note-search",
        "handler": "knowledgeSearchRoute",
        "title": "Search knowledge notes route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "POST",
        "path": "/knowledge/image",
        "handler": "knowledgeUploadImageRoute",
        "title": "Upload knowledge image route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "POST",
        "path": "/knowledge/share-import",
        "handler": "knowledgeImportUrlRoute",
        "title": "Import item into knowledge route",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "GET",
        "path": "/knowledge/events",
        "handler": "knowledgeEventsRoute",
        "title": "Watch knowledge events",
        "stream": "sse",
        "worker": {
          "enabled": true
        }
      },
      {
        "method": "GET",
        "path": "/memory",
        "handler": "memoryRoute",
        "title": "Read memory context route",
        "worker": {
          "enabled": true
        }
      }
    ]
  },
  "contributes": {
    "promptReferences": [
      {
        "id": "knowledge-files",
        "handler": "resolvePromptReferences",
        "title": "Knowledge files"
      }
    ],
    "instructionProviders": [
      {
        "id": "knowledge-paths",
        "handler": "provideKnowledgeInstructions",
        "title": "Knowledge paths",
        "priority": 925
      }
    ],
    "quickOpen": [
      {
        "id": "knowledge-files",
        "provider": "knowledgeQuickOpenProvider",
        "title": "Knowledge files",
        "section": "files",
        "order": 10
      }
    ],
    "commands": [
      {
        "id": "open-knowledge-files-palette",
        "title": "Open knowledge files palette",
        "action": "palette.open",
        "args": {
          "scope": "files"
        }
      }
    ],
    "keybindings": [
      {
        "id": "open-knowledge-files-palette",
        "title": "Open knowledge files palette",
        "keys": ["mod+alt+p"],
        "command": "palette.open",
        "args": {
          "scope": "files"
        }
      }
    ],
    "settingsComponent": {
      "id": "knowledge-base",
      "component": "KnowledgeSettingsPanel",
      "sectionId": "settings-knowledge-base",
      "label": "Knowledge Base",
      "description": "Connect or update the git repository used for durable knowledge sync.",
      "order": 25
    },
    "mentions": [
      {
        "id": "knowledge-files",
        "title": "Knowledge files",
        "description": "Adds knowledge notes, folders, and files to the conversation @ menu.",
        "kinds": ["note", "folder", "file"],
        "provider": "buildKnowledgeMentionItems"
      }
    ],
    "nav": [
      {
        "id": "knowledge",
        "label": "Knowledge",
        "route": "/knowledge",
        "icon": "file",
        "sidebarView": "knowledge-sidebar"
      }
    ],
    "views": [
      {
        "id": "knowledge-page",
        "title": "Knowledge",
        "location": "main",
        "route": "/knowledge",
        "component": "KnowledgePageSurface",
        "routeCapabilities": ["knowledgeFiles"],
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      },
      {
        "id": "knowledge-sidebar",
        "title": "Knowledge",
        "location": "sidebar",
        "component": "KnowledgeTreePanel",
        "icon": "file",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      },
      {
        "id": "knowledge-tree",
        "title": "Knowledge",
        "location": "rightRail",
        "scope": "global",
        "component": "KnowledgeTreePanel",
        "icon": "file",
        "detailView": "knowledge-file",
        "placement": "workbench-tool",
        "activation": "on-open",
        "persistOpen": true,
        "toolSlot": "knowledge"
      },
      {
        "id": "knowledge-file",
        "title": "Knowledge file",
        "location": "workbench",
        "component": "KnowledgeFilePanel",
        "placement": "workbench-tool",
        "scope": "global",
        "activation": "on-open",
        "persistOpen": true
      }
    ]
  },
  "permissions": ["knowledge:read", "knowledge:write"],
  "compatibility": {
    "neonPilot": ">=0.10.0"
  }
}
