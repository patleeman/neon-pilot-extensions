{
  "schemaVersion": 2,
  "id": "system-video-probe",
  "name": "Video Probe",
  "packageType": "system",
  "defaultEnabled": false,
  "description": "Analyze video files using a video-capable model. Manages a local mlx-vlm runtime (Apple Silicon) or routes to OpenRouter.",
  "version": "0.1.0",
  "frontend": {
    "entry": "dist/frontend.js"
  },
  "backend": {
    "entry": "dist/backend.mjs",
    "agentExtension": "createVideoProbeAgentExtension",
    "actions": [
      {
        "id": "videoProbeStatus",
        "handler": "status",
        "title": "Video probe status",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "videoProbeSetup",
        "handler": "setup",
        "title": "Install runtime and download model",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "videoProbeStart",
        "handler": "startServer",
        "title": "Start mlx-vlm server",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "videoProbeStop",
        "handler": "stopServer",
        "title": "Stop mlx-vlm server",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "videoProbeReadSettings",
        "handler": "readSettings",
        "title": "Read video probe settings",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "videoProbeWriteSettings",
        "handler": "writeSettings",
        "title": "Write video probe settings",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "videoProbeCancel",
        "handler": "cancelSetup",
        "title": "Cancel setup",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "videoProbeReset",
        "handler": "resetInstallation",
        "title": "Reset installation",
        "worker": {
          "enabled": true
        }
      }
    ]
  },
  "contributes": {
    "views": [
      {
        "id": "main",
        "title": "Video Probe",
        "location": "main",
        "route": "/ext/system-video-probe",
        "component": "VideoProbePage"
      }
    ],
    "nav": [
      {
        "id": "system-video-probe",
        "label": "Video Probe",
        "icon": "app",
        "route": "/ext/system-video-probe"
      }
    ],
    "secrets": {
      "hfToken": {
        "label": "Hugging Face token",
        "description": "Optional read-only token used to download local video models.",
        "env": "HF_TOKEN",
        "placeholder": "hf_...",
        "order": 10
      }
    },
    "tools": []
  },
  "permissions": [
    "secrets:read",
    "shell:execute"
  ],
  "compatibility": {
    "neonPilot": ">=0.10.0 <0.11.0",
    "extensionApi": "^2"
  }
}
