{
  "schemaVersion": 2,
  "id": "system-writing-studio",
  "name": "Writing Studio",
  "packageType": "user",
  "description": "Document-first collaborative markdown editor with CRDT replay, agent annotations, reactions, suggestions, and chat.",
  "version": "0.1.2",
  "defaultEnabled": false,
  "frontend": {
    "entry": "dist/frontend.js",
    "styles": []
  },
  "backend": {
    "entry": "dist/backend.mjs",
    "actions": [
      {
        "id": "writingStudioLoad",
        "handler": "load",
        "title": "Load writing document",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioListDocuments",
        "handler": "listDocuments",
        "title": "List writing documents",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioCreateDocument",
        "handler": "createDocument",
        "title": "Create writing document",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioCreateFolder",
        "handler": "createFolder",
        "title": "Create writing folder",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioRenameDocument",
        "handler": "renameDocument",
        "title": "Rename writing document",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioDeleteDocument",
        "handler": "deleteDocument",
        "title": "Delete writing document",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioRenameFolder",
        "handler": "renameFolder",
        "title": "Rename writing folder",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioDeleteFolder",
        "handler": "deleteFolder",
        "title": "Delete writing folder",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioImportDocument",
        "handler": "importDocument",
        "title": "Import writing document",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioSaveDocument",
        "handler": "saveDocument",
        "title": "Save writing document",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioExportDocument",
        "handler": "exportDocument",
        "title": "Export writing document",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioAppendUpdate",
        "handler": "appendUpdate",
        "title": "Append writing CRDT update",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioReplayDocument",
        "handler": "replayDocument",
        "title": "Replay writing document",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioRunReview",
        "handler": "runReview",
        "title": "Review writing document",
        "worker": {
          "enabled": true,
          "timeoutMs": 120000
        }
      },
      {
        "id": "writingStudioReviewSelection",
        "handler": "reviewSelection",
        "title": "Review selected writing text",
        "worker": {
          "enabled": true,
          "timeoutMs": 60000
        }
      },
      {
        "id": "writingStudioEnsureChatSession",
        "handler": "ensureChatSession",
        "title": "Ensure Writing Studio chat session",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioClearChat",
        "handler": "clearChat",
        "title": "Clear Writing Studio chat",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioSaveSettings",
        "handler": "saveSettings",
        "title": "Save writing studio settings",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioGetAgentInstructions",
        "handler": "getAgentInstructions",
        "title": "Get Writing Studio agent instructions",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioUpdateAgentInstructions",
        "handler": "updateAgentInstructions",
        "title": "Update Writing Studio agent instructions",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioResolveAnnotation",
        "handler": "resolveAnnotation",
        "title": "Resolve writing annotation",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioGetCanvas",
        "handler": "getCanvas",
        "title": "Get Writing Studio canvas",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioUpdateCanvas",
        "handler": "updateCanvas",
        "title": "Update Writing Studio canvas",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioAddAnnotation",
        "handler": "addAnnotation",
        "title": "Add Writing Studio annotation",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioUpdateAnnotation",
        "handler": "updateAnnotation",
        "title": "Update Writing Studio annotation",
        "worker": {
          "enabled": true
        }
      },
      {
        "id": "writingStudioApplyAnnotationEdit",
        "handler": "applyAnnotationEdit",
        "title": "Apply Writing Studio annotation edit",
        "worker": {
          "enabled": true
        }
      }
    ]
  },
  "contributes": {
    "views": [
      {
        "id": "page",
        "title": "Writing Studio",
        "location": "main",
        "route": "/ext/writing-studio",
        "component": "WritingStudioPage",
        "placement": "primary",
        "scope": "global",
        "activation": "on-route"
      },
      {
        "id": "documents-sidebar",
        "title": "Writing Studio Documents",
        "location": "sidebar",
        "component": "WritingStudioSidebar",
        "scope": "global",
        "activation": "on-route"
      }
    ],
    "nav": [
      {
        "id": "nav",
        "label": "Writing Studio",
        "route": "/ext/writing-studio",
        "icon": "sparkle",
        "sidebarView": "documents-sidebar"
      }
    ],
    "tools": [
      {
        "id": "get-canvas",
        "name": "writing_studio_get_canvas",
        "description": "Read the active Writing Studio document, markdown canvas, open comments, and document list.",
        "action": "writingStudioGetCanvas",
        "activation": "explicit",
        "inputSchema": {
          "type": "object",
          "properties": {
            "documentId": {
              "type": "string",
              "description": "Optional Writing Studio document id. Defaults to the active document."
            }
          },
          "additionalProperties": false
        }
      },
      {
        "id": "update-canvas",
        "name": "writing_studio_update_canvas",
        "description": "Replace the markdown content of a Writing Studio document.",
        "action": "writingStudioUpdateCanvas",
        "activation": "explicit",
        "inputSchema": {
          "type": "object",
          "properties": {
            "documentId": {
              "type": "string",
              "description": "Optional Writing Studio document id. Defaults to the active document."
            },
            "markdown": {
              "type": "string",
              "description": "Full replacement markdown for the canvas."
            },
            "title": {
              "type": "string",
              "description": "Optional document title."
            }
          },
          "required": [
            "markdown"
          ],
          "additionalProperties": false
        },
        "promptGuidelines": [
          "Read the canvas first and preserve user intent; this tool replaces the full document.",
          "When the user asks for edits, rewrites, a final document, or changes that resolve comments, call this tool with the full updated markdown instead of only writing the edited document in chat."
        ]
      },
      {
        "id": "add-annotation",
        "name": "writing_studio_add_annotation",
        "description": "Add a floating Writing Studio comment, suggestion, reaction, or warning anchored to an exact quote in the canvas.",
        "action": "writingStudioAddAnnotation",
        "activation": "explicit",
        "inputSchema": {
          "type": "object",
          "properties": {
            "documentId": {
              "type": "string",
              "description": "Optional Writing Studio document id. Defaults to the active document."
            },
            "quote": {
              "type": "string",
              "description": "Exact substring from the canvas to anchor the annotation."
            },
            "body": {
              "type": "string",
              "description": "Comment text to show beside the document."
            },
            "kind": {
              "type": "string",
              "enum": [
                "comment",
                "suggestion",
                "reaction",
                "warning"
              ]
            },
            "emoji": {
              "type": "string",
              "description": "Optional short emoji or marker for reactions."
            },
            "suggestedReplacement": {
              "type": "string",
              "description": "Optional exact replacement text the user can approve to replace quote."
            }
          },
          "required": [
            "quote",
            "body"
          ],
          "additionalProperties": false
        },
        "promptGuidelines": [
          "Anchor comments to exact quotes and write like a generous collaborator, not a proofreader."
        ]
      },
      {
        "id": "review-canvas",
        "name": "writing_studio_review_canvas",
        "description": "Run the Writing Studio review pipeline for the active document and add generated annotations.",
        "action": "writingStudioRunReview",
        "activation": "explicit",
        "inputSchema": {
          "type": "object",
          "properties": {
            "documentId": {
              "type": "string",
              "description": "Optional Writing Studio document id. Defaults to the active document."
            },
            "trigger": {
              "type": "string",
              "description": "Why the review is being run."
            }
          },
          "additionalProperties": false
        }
      },
      {
        "id": "resolve-annotation",
        "name": "writing_studio_resolve_annotation",
        "description": "Resolve an open Writing Studio annotation by id.",
        "action": "writingStudioResolveAnnotation",
        "activation": "explicit",
        "inputSchema": {
          "type": "object",
          "properties": {
            "documentId": {
              "type": "string",
              "description": "Optional Writing Studio document id. Defaults to the active document."
            },
            "id": {
              "type": "string",
              "description": "Annotation id to resolve."
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false
        }
      },
      {
        "id": "update-annotation",
        "name": "writing_studio_update_annotation",
        "description": "Update an existing Writing Studio annotation body, kind, emoji, or exact quote anchor.",
        "action": "writingStudioUpdateAnnotation",
        "activation": "explicit",
        "inputSchema": {
          "type": "object",
          "properties": {
            "documentId": {
              "type": "string",
              "description": "Optional Writing Studio document id. Defaults to the active document."
            },
            "id": {
              "type": "string",
              "description": "Annotation id to update."
            },
            "quote": {
              "type": "string",
              "description": "Optional replacement exact substring from the canvas."
            },
            "body": {
              "type": "string",
              "description": "Optional replacement comment text."
            },
            "kind": {
              "type": "string",
              "enum": [
                "comment",
                "suggestion",
                "reaction",
                "warning"
              ]
            },
            "emoji": {
              "type": "string",
              "description": "Optional short emoji or marker for reactions."
            },
            "suggestedReplacement": {
              "type": "string",
              "description": "Optional exact replacement text the user can approve to replace the quote."
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false
        },
        "promptGuidelines": [
          "Use this when the user asks to revise a margin comment without changing the document text."
        ]
      },
      {
        "id": "apply-annotation-edit",
        "name": "writing_studio_apply_annotation_edit",
        "description": "Apply an approved Writing Studio annotation replacement and resolve that annotation.",
        "action": "writingStudioApplyAnnotationEdit",
        "activation": "explicit",
        "inputSchema": {
          "type": "object",
          "properties": {
            "documentId": {
              "type": "string",
              "description": "Optional Writing Studio document id. Defaults to the active document."
            },
            "id": {
              "type": "string",
              "description": "Annotation id with a suggested replacement to apply."
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false
        },
        "promptGuidelines": [
          "Use only after the user approves a suggested edit."
        ]
      },
      {
        "id": "get-agent-instructions",
        "name": "writing_studio_get_agent_instructions",
        "description": "Read the current Writing Studio agent instructions for the active document.",
        "action": "writingStudioGetAgentInstructions",
        "activation": "explicit",
        "inputSchema": {
          "type": "object",
          "properties": {
            "documentId": {
              "type": "string",
              "description": "Optional Writing Studio document id. Defaults to the active document."
            }
          },
          "additionalProperties": false
        }
      },
      {
        "id": "update-agent-instructions",
        "name": "writing_studio_update_agent_instructions",
        "description": "Update the Writing Studio agent's own per-document instructions.",
        "action": "writingStudioUpdateAgentInstructions",
        "activation": "explicit",
        "inputSchema": {
          "type": "object",
          "properties": {
            "documentId": {
              "type": "string",
              "description": "Optional Writing Studio document id. Defaults to the active document."
            },
            "instructions": {
              "type": "string",
              "description": "New instructions for the Writing Studio agent."
            },
            "append": {
              "type": "boolean",
              "description": "Append to the existing instructions instead of replacing them."
            }
          },
          "required": [
            "instructions"
          ],
          "additionalProperties": false
        },
        "promptGuidelines": [
          "Use this when the user asks you to remember or change how you should behave in Writing Studio."
        ]
      }
    ]
  },
  "permissions": [
    "storage:readwrite",
    "agent:run",
    "agent:conversations"
  ],
  "compatibility": {
    "neonPilot": ">=0.10.0 <0.12.0",
    "extensionApi": "^2"
  }
}
